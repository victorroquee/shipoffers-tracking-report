# =============================================================================
# Shipoffers Tracking Dashboard — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# Variables marked "REQUIRED" must be set before the app works in production.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local development: use SQLite
# DATABASE_URL="file:./dev.db"
#
# Production (Vercel Postgres): obtain from Vercel dashboard after provisioning
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# -----------------------------------------------------------------------------
# Shipoffers API
# Pending from Ben Schulz (tech team) — use USE_MOCK=true until credentials arrive
# -----------------------------------------------------------------------------
# REQUIRED: Basic Auth username provided by Shipoffers
SHIPOFFERS_API_USER="your_shipoffers_username"

# REQUIRED: Basic Auth password provided by Shipoffers
SHIPOFFERS_API_PASS="your_shipoffers_password"

# REQUIRED: Store identifier required in all Shipoffers API requests
SHIPOFFERS_STORE_ID="your_store_id"

# Base URL for Shipoffers API (default is correct for production)
SHIPOFFERS_API_URL="https://api.shipoffers.com"

# Set to false when Shipoffers credentials are configured and ready
# Set to true to run the dashboard with mock/sample data (safe default)
USE_MOCK="true"

# -----------------------------------------------------------------------------
# 17track API
# Used for package tracking status lookups (max 40 codes per request)
# -----------------------------------------------------------------------------
# REQUIRED: API key from https://www.17track.net/en/apiDoc
SEVENTEENTRACK_API_KEY="your_17track_api_key"

# Base URL for 17track API (default is correct)
SEVENTEENTRACK_API_URL="https://api.17track.net/track/v2"

# -----------------------------------------------------------------------------
# Email / SMTP
# Used to send delay alert emails to the Shipoffers team
# -----------------------------------------------------------------------------
# REQUIRED: SMTP server hostname (e.g., smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST="smtp.gmail.com"

# REQUIRED: SMTP port (587 for TLS, 465 for SSL)
SMTP_PORT="587"

# REQUIRED: SMTP authentication username (usually your email address)
SMTP_USER="your_email@example.com"

# REQUIRED: SMTP authentication password or app-specific password
SMTP_PASS="your_smtp_password"

# REQUIRED: Sender display name and address for outgoing alert emails
ALERT_FROM="Tracker OG Group <your_email@example.com>"

# REQUIRED: Recipient email address for delay alert notifications
ALERT_TO_SHIPOFFERS="suporte@shipoffers.com"

# -----------------------------------------------------------------------------
# Dashboard Authentication (HTTP Basic Auth)
# -----------------------------------------------------------------------------
# REQUIRED: Set a secure username for production — do not use the default
DASHBOARD_USER="CHANGE_ME"

# REQUIRED: Set a secure password for production — do not use the default
DASHBOARD_PASS="CHANGE_ME"

# -----------------------------------------------------------------------------
# Cron Job Security
# All cron endpoints validate the Authorization header against this secret
# -----------------------------------------------------------------------------
# REQUIRED: Use a cryptographically random string for production
# Generate with: openssl rand -hex 32
CRON_SECRET="CHANGE_ME_GENERATE_RANDOM_TOKEN"
