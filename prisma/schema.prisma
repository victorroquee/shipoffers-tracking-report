// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // URL is configured at runtime via prisma.config.ts (Prisma 7 pattern)
  // Local dev: DATABASE_URL="file:./dev.db" uses SQLite via adapter
  // Production: DATABASE_URL="postgresql://..." uses Vercel Postgres via adapter
}

model Order {
  id                 String       @id @default(cuid())
  shipofffersId      String       @unique
  trackingCode       String?
  customerName       String?
  customerEmail      String?
  destinationCountry String?
  shippedAt          DateTime?
  deliveredAt        DateTime?
  status             String       @default("UNKNOWN")
  lastTrackingSync   DateTime?
  daysInTransit      Int?
  delayThreshold     Int?
  isDelayed          Boolean      @default(false)
  alertSentAt        DateTime?
  rawTrackingData    String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  events             OrderEvent[]
}

model OrderEvent {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  status      String
  description String?
  occurredAt  DateTime
  createdAt   DateTime @default(now())
}

model DelayThreshold {
  id          String   @id @default(cuid())
  countryCode String   @unique
  countryName String
  days        Int
  updatedAt   DateTime @updatedAt
}
