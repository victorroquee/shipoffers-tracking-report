// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Adapter pattern: actual DB selected at runtime in lib/db.ts
  // URL configured in prisma.config.ts (Prisma 7 pattern)
}

model Order {
  id                 String       @id @default(cuid())
  shipofffersId      String       @unique
  trackingCode       String?
  customerName       String?
  customerEmail      String?
  destinationCountry String?
  orderedAt          DateTime?    // Date the customer placed the order (countdown starts here)
  shippedAt          DateTime?
  deliveredAt        DateTime?
  status             String       @default("UNKNOWN")
  lastTrackingSync   DateTime?
  daysSinceOrder     Int?         // Days since orderedAt (the real delay metric)
  daysInTransit      Int?         // Days since shippedAt (for reference only)
  delayThreshold     Int?
  isDelayed          Boolean      @default(false)
  alertSentAt        DateTime?
  rawTrackingData    String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  events             OrderEvent[]
}

model OrderEvent {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  status      String
  description String?
  occurredAt  DateTime
  createdAt   DateTime @default(now())
}

model DelayThreshold {
  id          String   @id @default(cuid())
  countryCode String   @unique
  countryName String
  days        Int
  updatedAt   DateTime @updatedAt
}
